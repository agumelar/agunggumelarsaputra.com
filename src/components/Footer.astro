---
const socialLinks = [
  { href: 'https://github.com/agumelar', label: 'GitHub' },
  { href: 'https://linkedin.com/in/agunggumelarsaputra', label: 'LinkedIn' },
  { href: 'mailto:agumelarsaputra@gmail.com', label: 'Email' },
];

const currentYear = new Date().getFullYear();
---

<footer class="border-t bg-card">
  <div class="container-main py-8 md:py-12">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex flex-col items-center md:items-start gap-2">
        <p class="text-sm text-muted-foreground">
          &copy; {currentYear} Agung Gumelar Saputra. All rights reserved.
        </p>
        <p class="text-xs text-muted-foreground">
          Built with Astro & TailwindCSS • Hosted on VPS with Caddy
        </p>
      </div>
      
      <div class="flex items-center gap-4">
        {socialLinks.map((link) => (
          <a 
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-medium text-muted-foreground hover:text-primary transition-colors"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
